---
import { stops } from '../scripts/stops';
import '../styles/app.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <meta name="description" content="Next departures at your stops" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Stops</title>
  </head>
  <body>
    <div class="app">
      <nav class="tabs" id="tabs">
        {stops.map((stop, i) => (
          <div class={`tab ${i === 0 ? 'active' : ''}`} data-id={stop.id}>
            {stop.name}
          </div>
        ))}
      </nav>
      <div class="slides-wrapper">
        <div class="ptr animating" id="ptr">
          <span class="ptr-spinner"></span>
          <span class="ptr-text">Pull to refresh</span>
        </div>
        <div class="slides" id="slides">
          {stops.map((stop) => (
            <div class="slide" data-stop-id={stop.id}>
              <div class="loading"><div class="spinner"></div>Loading…</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <script define:vars={{ stops }}>
      const slidesEl = document.getElementById('slides');
      const tabsEl = document.getElementById('tabs');
      const ptr = document.getElementById('ptr');
      const ptrText = ptr.querySelector('.ptr-text');

      let order = stops.slice();
      let current = 0;
      let startX = 0;
      let startY = 0;
      let deltaX = 0;
      let pullY = 0;
      let axis = null;
      let isDragging = false;
      let refreshing = false;
      const cache = {};

      function tabById(id) {
        return tabsEl.querySelector('.tab[data-id="' + id + '"]');
      }
      function slideById(id) {
        return slidesEl.querySelector('.slide[data-stop-id="' + id + '"]');
      }
      function curSlide() {
        return slideById(order[current].id);
      }

      function updateActiveTab() {
        const id = order[current].id;
        [...tabsEl.children].forEach((t) => t.classList.toggle('active', t.dataset.id === id));
      }

      function centerTab(id) {
        const tab = tabById(id);
        if (!tab) return;
        const target = tab.offsetLeft - (tabsEl.clientWidth - tab.offsetWidth) / 2;
        const max = tabsEl.scrollWidth - tabsEl.clientWidth;
        tabsEl.scrollTo({ left: Math.max(0, Math.min(target, max)), behavior: 'smooth' });
      }

      function setSlideTransform(idx, instant) {
        if (instant) {
          slidesEl.style.transition = 'none';
          slidesEl.style.transform = `translateX(-${idx * 100}%)`;
          void slidesEl.offsetWidth;
          slidesEl.style.transition = '';
        } else {
          slidesEl.style.transform = `translateX(-${idx * 100}%)`;
        }
      }

      function goTo(index) {
        current = Math.max(0, Math.min(index, order.length - 1));
        setSlideTransform(current, false);
        updateActiveTab();
        centerTab(order[current].id);
        loadDepartures(current);
      }

      [...tabsEl.children].forEach((tab) => {
        tab.addEventListener('click', () => {
          const idx = order.findIndex((s) => s.id === tab.dataset.id);
          if (idx >= 0) goTo(idx);
        });
      });

      function haversine(a, b) {
        const R = 6371000;
        const toRad = (d) => (d * Math.PI) / 180;
        const dLat = toRad(b[1] - a[1]);
        const dLng = toRad(b[0] - a[0]);
        const lat1 = toRad(a[1]);
        const lat2 = toRad(b[1]);
        const h =
          Math.sin(dLat / 2) ** 2 + Math.cos(lat1) * Math.cos(lat2) * Math.sin(dLng / 2) ** 2;
        return 2 * R * Math.asin(Math.sqrt(h));
      }

      function saveLastPos(me) {
        try {
          localStorage.setItem('freqstops:pos', JSON.stringify(me));
        } catch (e) {
          /* ignore */
        }
      }

      function readLastPos() {
        try {
          const p = JSON.parse(localStorage.getItem('freqstops:pos'));
          return Array.isArray(p) && p.length === 2 ? p : null;
        } catch (e) {
          return null;
        }
      }

      function getPosition() {
        return new Promise((resolve, reject) => {
          if (!navigator.geolocation) return reject(new Error('no geolocation'));
          navigator.geolocation.getCurrentPosition(
            (pos) => {
              const me = [pos.coords.longitude, pos.coords.latitude];
              saveLastPos(me);
              resolve(me);
            },
            reject,
            { enableHighAccuracy: false, maximumAge: 60000, timeout: 8000 },
          );
        });
      }

      function sortedByProximity(me) {
        return order
          .map((s) => ({ s, d: s.coords ? haversine(me, s.coords) : Infinity }))
          .sort((a, b) => a.d - b.d)
          .map((x) => x.s);
      }

      function orderChanged(newOrder) {
        return newOrder.some((s, i) => s.id !== order[i].id);
      }

      function reorderDom(newOrder, animate) {
        const doReorder = () => {
          newOrder.forEach((stop) => tabsEl.appendChild(tabById(stop.id)));
          newOrder.forEach((stop) => slidesEl.appendChild(slideById(stop.id)));
        };

        if (!animate) {
          doReorder();
          return;
        }

        const first = new Map();
        [...tabsEl.children].forEach((el) => first.set(el, el.getBoundingClientRect().left));
        doReorder();
        [...tabsEl.children].forEach((el) => {
          const prevLeft = first.get(el);
          if (prevLeft == null) return;
          const dx = prevLeft - el.getBoundingClientRect().left;
          if (!dx) return;
          el.style.transition = 'none';
          el.style.transform = `translateX(${dx}px)`;
          requestAnimationFrame(() => {
            el.style.transition = 'transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
            el.style.transform = '';
          });
          el.addEventListener(
            'transitionend',
            () => {
              el.style.transition = '';
              el.style.transform = '';
            },
            { once: true },
          );
        });
      }

      async function resortKeepingCurrent(animate) {
        let me;
        try {
          me = await getPosition();
        } catch (e) {
          return;
        }
        const currentId = order[current].id;
        const newOrder = sortedByProximity(me);
        if (!orderChanged(newOrder)) return;

        reorderDom(newOrder, animate);
        order = newOrder;
        current = Math.max(0, order.findIndex((s) => s.id === currentId));
        setSlideTransform(current, true);
        updateActiveTab();
        centerTab(order[current].id);
      }

      async function initialSort() {
        let me;
        try {
          me = await getPosition();
        } catch (e) {
          return;
        }
        const newOrder = sortedByProximity(me);
        if (!orderChanged(newOrder)) return;

        reorderDom(newOrder, true);
        order = newOrder;
        current = 0;
        setSlideTransform(0, true);
        updateActiveTab();
        centerTab(order[0].id);
        loadDepartures(0);
      }

      slidesEl.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        deltaX = 0;
        pullY = 0;
        axis = null;
        isDragging = true;
      });

      slidesEl.addEventListener(
        'touchmove',
        (e) => {
          if (!isDragging) return;
          const dx = e.touches[0].clientX - startX;
          const dy = e.touches[0].clientY - startY;

          if (!axis) {
            if (Math.abs(dx) < 8 && Math.abs(dy) < 8) return;
            axis = Math.abs(dx) > Math.abs(dy) ? 'h' : 'v';
            if (axis === 'h') slidesEl.classList.add('dragging');
            if (axis === 'v') {
              ptr.classList.remove('animating');
              curSlide().classList.add('pulling');
            }
          }

          if (axis === 'h') {
            deltaX = dx;
            const offset = -(current * window.innerWidth) + deltaX;
            slidesEl.style.transform = `translateX(${offset}px)`;
          } else if (!refreshing && curSlide().scrollTop <= 0 && dy > 0) {
            e.preventDefault();
            pullY = Math.min(dy * 0.5, 90);
            ptr.style.transform = `translateY(${pullY}px)`;
            curSlide().style.transform = `translateY(${pullY}px)`;
            const ready = pullY > 56;
            ptr.classList.toggle('ready', ready);
            ptrText.textContent = ready ? 'Release to refresh all' : 'Pull to refresh';
          }
        },
        { passive: false },
      );

      slidesEl.addEventListener('touchend', () => {
        if (!isDragging) return;
        isDragging = false;
        slidesEl.classList.remove('dragging');

        if (axis === 'h') {
          if (Math.abs(deltaX) > 60) {
            if (deltaX < 0 && current < order.length - 1) goTo(current + 1);
            else if (deltaX > 0 && current > 0) goTo(current - 1);
            else goTo(current);
          } else {
            goTo(current);
          }
        } else if (axis === 'v') {
          curSlide().classList.remove('pulling');
          if (pullY > 56 && !refreshing) refreshAll();
          else resetPtr();
        }

        deltaX = 0;
        pullY = 0;
        axis = null;
      });

      function resetPtr() {
        ptr.classList.add('animating');
        ptr.classList.remove('ready', 'refreshing');
        ptr.style.transform = '';
        ptrText.textContent = 'Pull to refresh';
        const cs = curSlide();
        cs.classList.remove('pulling');
        cs.style.transform = '';
      }

      async function refreshAll() {
        refreshing = true;
        ptr.classList.add('animating', 'refreshing');
        ptr.classList.remove('ready');
        ptr.style.transform = 'translateY(56px)';
        const cs = curSlide();
        cs.classList.remove('pulling');
        cs.style.transform = 'translateY(56px)';
        ptrText.textContent = 'Refreshing…';

        for (const s of order) cache[s.id] = null;
        try {
          await Promise.all(order.map((s, i) => loadDepartures(i, true)));
        } catch (e) {
        }
        await resortKeepingCurrent(true);
        refreshing = false;
        resetPtr();
      }

      async function loadDepartures(index, force) {
        const stop = order[index];
        const slide = slideById(stop.id);
        const now = Date.now();

        if (!force && cache[stop.id] && now - cache[stop.id].time < 30000) {
          render(slide, cache[stop.id].data, stop);
          return;
        }

        if (!slide.querySelector('.dep-list')) {
          slide.innerHTML = '<div class="loading"><div class="spinner"></div>Loading…</div>';
        }

        try {
          const res = await fetch(`/api/departures?stopId=${stop.id}`);
          const data = await res.json();
          cache[stop.id] = { data, time: Date.now() };
          render(slide, data, stop);
        } catch (e) {
          if (!slide.querySelector('.dep-list')) {
            slide.innerHTML = '<div class="error">Failed to load</div>';
          }
        }
      }

      function keyOf(dep) {
        return `${dep.line}|${dep.direction}|${dep.scheduledTime}`;
      }

      function normLine(line) {
        return String(line ?? '').trim().toUpperCase();
      }

      const COMPASS = { N: 0, NE: 45, E: 90, SE: 135, S: 180, SW: 225, W: 270, NW: 315 };
      const DIR_TOL = 65;

      function toBearing(v) {
        if (v == null) return null;
        if (typeof v === 'number') return ((v % 360) + 360) % 360;
        const key = String(v).trim().toUpperCase();
        return key in COMPASS ? COMPASS[key] : null;
      }

      function parseDir(spec) {
        if (spec == null) return null;
        let to = spec;
        let tol = DIR_TOL;
        if (typeof spec === 'object') {
          to = spec.to;
          if (typeof spec.tol === 'number') tol = spec.tol;
        }
        const bearing = toBearing(to);
        return bearing == null ? null : { bearing, tol };
      }

      function angDiff(a, b) {
        const d = Math.abs(a - b) % 360;
        return d > 180 ? 360 - d : d;
      }

      function departTime(dep) {
        return dep.scheduledTime
          ? new Date(dep.scheduledTime).toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' })
          : '';
      }

      function badgeMarkup(dep) {
        const badge = dep.badge || { background: '#4B5563', color: '#fff', shape: 'circle' };
        const shapeClass = badge.shape === 'circle' ? 'circle' : 'rect';
        const lineText = String(dep.line ?? '');
        const lenClass = 'len-' + Math.min(lineText.length || 1, 4);
        return `<div class="line-badge ${shapeClass} ${lenClass}" style="background:${badge.background};color:${badge.color}">${lineText}</div>`;
      }

      function infoMarkup(dep) {
        return `<div class="dep-info"><div class="dep-direction">${dep.direction}</div><div class="dep-depart"></div></div>`;
      }

      function timeMarkup(dep) {
        const mins = dep.minutesUntil;
        const delay = Number(dep.delayTime) || 0;
        const isCancelled = dep.state === 'Cancelled';
        const timeStr = mins <= 0 ? 'now' : `${mins}<span class="unit">min</span>`;
        const timeClass = mins <= 0 ? 'now' : '';

        let delayHtml;
        if (isCancelled) delayHtml = '<span class="dep-delay cancelled">Cancelled</span>';
        else if (delay > 0) delayHtml = `<span class="dep-delay late">+${delay} min</span>`;
        else if (delay < 0) delayHtml = `<span class="dep-delay early">${delay} min</span>`;
        else delayHtml = '<span class="dep-delay ontime">on time</span>';

        return `<div class="dep-time ${timeClass}">${timeStr}</div>${delayHtml}`;
      }

      function updateNode(node, dep, isNew, highlight) {
        node.classList.toggle('cancelled', dep.state === 'Cancelled');
        node.classList.toggle('highlight', !!highlight);

        const departEl = node.querySelector('.dep-depart');
        if (departEl) {
          const t = departTime(dep);
          if (departEl.textContent !== t) departEl.textContent = t;
        }

        const right = node.querySelector('.dep-right');
        const sig = timeMarkup(dep);
        if (right.dataset.sig !== sig) {
          right.innerHTML = sig;
          right.dataset.sig = sig;
          if (!isNew) {
            right.classList.remove('flash');
            void right.offsetWidth;
            right.classList.add('flash');
          }
        }
      }

      function createNode(dep, highlight) {
        const node = document.createElement('div');
        node.className = 'departure';
        node.dataset.key = keyOf(dep);
        node.innerHTML = badgeMarkup(dep) + infoMarkup(dep) + '<div class="dep-right"></div>';
        updateNode(node, dep, true, highlight);
        return node;
      }

      function render(slide, data, stop) {
        const deps = (data && data.departures) || [];

        if (deps.length === 0) {
          slide.innerHTML = '<div class="empty">No departures</div>';
          return;
        }

        const loi = new Set(((stop && stop.linesOfInterest) || []).map(normLine));
        const dirs = (stop && stop.directions) || {};
        const hasOtherLines = deps.some((d) => !loi.has(normLine(d.line)));

        function isHighlighted(dep) {
          const line = normLine(dep.line);
          if (!loi.has(line)) return false;
          const spec = parseDir(dirs[line] ?? dirs[dep.line]);
          if (spec != null) {
            return dep.bearing != null && angDiff(dep.bearing, spec.bearing) <= spec.tol;
          }
          return hasOtherLines;
        }

        const hasHighlighted = deps.some((d) => isHighlighted(d));

        let list = slide.querySelector('.dep-list');
        if (!list) {
          slide.innerHTML = '<div class="dep-list"></div><div class="update-hint"></div>';
          list = slide.querySelector('.dep-list');
        }
        list.classList.toggle('has-highlights', hasHighlighted);

        const keys = deps.map(keyOf);
        const keySet = new Set(keys);

        const existing = {};
        [...list.children].forEach((node) => {
          if (node.classList.contains('leaving')) return;
          existing[node.dataset.key] = node;
        });

        [...list.children].forEach((node) => {
          if (node.classList.contains('leaving')) return;
          if (!keySet.has(node.dataset.key)) {
            node.classList.add('leaving');
            node.addEventListener('animationend', () => node.remove(), { once: true });
            setTimeout(() => node.parentNode && node.remove(), 500);
          }
        });

        let prev = null;
        deps.forEach((dep, i) => {
          const hl = isHighlighted(dep);
          let node = existing[keys[i]];
          if (node) {
            updateNode(node, dep, false, hl);
          } else {
            node = createNode(dep, hl);
            node.classList.add('entering');
            node.addEventListener('animationend', () => node.classList.remove('entering'), { once: true });
          }
          const ref = prev ? prev.nextSibling : list.firstChild;
          if (ref !== node) list.insertBefore(node, ref);
          prev = node;
        });

        const hint = slide.querySelector('.update-hint');
        if (hint) {
          hint.textContent =
            'Last updated: ' +
            new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
        }
      }

      setInterval(async () => {
        if (refreshing) return;
        cache[order[current].id] = null;
        await loadDepartures(current);
        resortKeepingCurrent(true);
      }, 30000);

      const cachedPos = readLastPos();
      if (cachedPos) {
        const cachedOrder = sortedByProximity(cachedPos);
        if (orderChanged(cachedOrder)) {
          reorderDom(cachedOrder, false);
          order = cachedOrder;
        }
      }

      goTo(0);
      initialSort();
    </script>
  </body>
</html>

